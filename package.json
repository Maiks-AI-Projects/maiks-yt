{
  "name": "maiks-yt",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "agent:brief": "node scripts/create-agent-brief.mjs",
    "check": "pnpm typecheck && pnpm test && pnpm check:architecture",
    "check:architecture": "node scripts/check-architecture.mjs",
    "db:generate": "pnpm --filter @maiks-yt/database db:generate",
    "db:migrate": "pnpm --filter @maiks-yt/database db:migrate",
    "db:seed": "pnpm --filter @maiks-yt/database db:seed",
    "dev": "turbo run dev --parallel",
    "review:start": "node scripts/start-session-review.mjs",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "2.9.16",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
