  "dependencies": {
    "drizzle-orm": "0.45.2",
    "mysql2": "3.22.5"
  },
  "devDependencies": {
    "@types/node": "24.10.2",
    "drizzle-kit": "0.31.10",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
